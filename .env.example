# Copy to .env.local. The editors are Claude-powered — set your key here.
# Without it, editors show clearly-labeled demo findings.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8)
ANTHROPIC_MODEL=

# Live federal job listings (free key: developer.usajobs.gov).
# Without these, Job Search shows clearly-labeled sample roles.
USAJOBS_API_KEY=
USAJOBS_EMAIL=
