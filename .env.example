# Copy to .env.local. The editors are Claude-powered — set your key here.
# Without it, editors show clearly-labeled demo findings.
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8)
ANTHROPIC_MODEL=

# Job Search ships on clearly-labeled sample roles by default — no credentials
# required, nothing to abuse on a public deployment. Live federal search is
# opt-in and OFF unless you flip the switch below AND supply your own free key
# (developer.usajobs.gov). A key alone never enables live search.
WAYPOINT_ENABLE_LIVE_JOBS=
USAJOBS_API_KEY=
USAJOBS_EMAIL=
