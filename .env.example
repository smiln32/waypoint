# Copy to .env.local.
#
# AI critique is sample-only by default. This public build sends NO document to
# an AI provider unless you turn live AI ON below AND supply your own key — a key
# alone never activates it. Without live AI the editors show clearly-labeled
# "Sample critique" demonstration findings.
WAYPOINT_ENABLE_LIVE_AI=
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8)
ANTHROPIC_MODEL=

# Job Search ships on clearly-labeled sample roles by default — no credentials
# required, nothing to abuse on a public deployment. Live federal search is
# opt-in and OFF unless you flip the switch below AND supply your own free key
# (developer.usajobs.gov). A key alone never enables live search.
WAYPOINT_ENABLE_LIVE_JOBS=
USAJOBS_API_KEY=
USAJOBS_EMAIL=
